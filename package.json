{
  "name": "shackw-wallet-server",
  "version": "0.1.0",
  "description": "Reference implementation of a transaction relay server for Shackw Wallet, enabling fixed-fee stablecoin transfers via EIP-7702 authorization.",
  "author": "Shackw",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "yarn format && yarn lint && nest build",
    "start": "nest start",
    "start:dev": "PORT=3010 dotenv -e .env -- nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "ngrok": "ngrok http http://localhost:3010",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "eslint src --fix"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/throttler": "^6.5.0",
    "@types/express": "^5.0.6",
    "dayjs": "^1.11.19",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "valibot": "^1.2.0",
    "viem": "^2.45.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.11",
    "@types/node": "^25.2.2",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
